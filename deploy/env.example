# PingMesh 集群部署敏感配置
# 复制为 deploy/.env 后填写（deploy/.env 已加入 .gitignore，勿提交）
#
#   cp deploy/env.example deploy/.env
#   chmod 600 deploy/.env

# SSH root 密码（批量部署脚本连接各节点用）
PINGMESH_SSH_PASSWORD=

# Agent 接入主节点的令牌（与主控「系统配置 → 基础设置 → 接入令牌」一致）
PINGMESH_JOIN_TOKEN=

# 首次部署主控制节点时创建的管理员（仅 cluster-deploy / redeploy-all 使用）
PINGMESH_ADMIN_USER=
PINGMESH_ADMIN_PASSWORD=

# 可选：覆盖默认内网/公网地址
# PINGMESH_MASTER_INTERNAL=10.100.1.8
# PINGMESH_BACKUP_INTERNAL=10.100.1.3
# PINGMESH_MASTER_PUBLIC=
# PINGMESH_BACKUP_PUBLIC=
